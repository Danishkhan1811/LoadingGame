---
import '../styles/global.css'

interface Props {
  title: string
  description?: string
}

const {
  title,
  description = 'Playable mini-games that replace loading spinners. Zero-dependency, <10kB per game, works with React, Vue, Svelte, or vanilla JS.',
} = Astro.props
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <style>
      nav {
        position: sticky;
        top: 0;
        z-index: 50;
        background: transparent;
        transition:
          background 0.3s ease,
          backdrop-filter 0.3s ease,
          border-color 0.3s ease;
        border-bottom: 1px solid transparent;
      }
      nav.scrolled {
        background: rgba(8, 8, 16, 0.82);
        backdrop-filter: blur(18px);
        -webkit-backdrop-filter: blur(18px);
        border-bottom-color: rgba(123, 0, 255, 0.12);
      }
      .nav-link {
        position: relative;
        color: #b0b0c8;
        font-size: 14px;
        font-weight: 500;
        text-decoration: none;
        padding-bottom: 2px;
        font-family: 'Plus Jakarta Sans', sans-serif;
        transition: color 0.15s;
      }
      .nav-link::after {
        content: '';
        position: absolute;
        bottom: -2px;
        left: 0;
        width: 100%;
        height: 1.5px;
        background: #9b30ff;
        transform: scaleX(0);
        transform-origin: left;
        transition: transform 0.22s ease;
      }
      .nav-link:hover {
        color: #fff;
      }
      .nav-link:hover::after {
        transform: scaleX(1);
      }

      .nav-github {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: 13px;
        font-weight: 600;
        color: #e0e0f0;
        background: transparent;
        border: 1px solid rgba(123, 0, 255, 0.35);
        padding: 6px 16px;
        border-radius: 100px;
        transition:
          border-color 0.2s ease,
          box-shadow 0.2s ease,
          color 0.2s ease;
        text-decoration: none;
        font-family: 'Plus Jakarta Sans', sans-serif;
      }
      .nav-github:hover {
        border-color: rgba(123, 0, 255, 0.7);
        box-shadow: 0 0 16px rgba(123, 0, 255, 0.25);
        color: #fff;
      }

      footer {
        background: #080810;
        border-top: 1px solid rgba(123, 0, 255, 0.1);
      }
      .footer-link {
        color: #6a6a8a;
        text-decoration: none;
        transition: color 0.15s;
        font-size: 13px;
      }
      .footer-link:hover {
        color: #9b30ff;
      }
    </style>
    <script>
      const nav = document.querySelector('nav')
      window.addEventListener(
        'scroll',
        () => {
          nav?.classList.toggle('scrolled', window.scrollY > 20)
        },
        { passive: true },
      )
    </script>
  </head>
  <body class="min-h-screen flex flex-col">
    <nav>
      <div class="mx-auto max-w-7xl flex items-center justify-between px-6 h-14">
        <a href="/" class="flex items-center gap-2.5" style="text-decoration:none">
          <svg
            width="32"
            height="32"
            viewBox="0 0 394 394"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
          >
            <rect x="69" y="150" width="256" height="94" rx="30" fill="#6700D6"></rect>
            <rect
              x="244"
              y="69"
              width="256"
              height="94"
              rx="30"
              transform="rotate(90 244 69)"
              fill="#6700D6"></rect>
            <path d="M176 297.615L217.615 256" stroke="white" stroke-width="4"></path>
            <path d="M217.615 297.615L176 256" stroke="white" stroke-width="4"></path>
            <rect x="94" y="174" width="46" height="46" stroke="white" stroke-width="4"></rect>
            <circle cx="276.5" cy="196.5" r="28.5" stroke="white" stroke-width="4"></circle>
            <path d="M224.713 133H169.287L197 85L224.713 133Z" stroke="white" stroke-width="4"
            ></path>
            <circle
              cx="197"
              cy="197"
              r="189.5"
              stroke="#6700D6"
              stroke-width="15"
              stroke-dasharray="60 20"></circle>
          </svg>

          <span
            style="font-family:'Familjen Grotesk',sans-serif;font-weight:700;font-size:22px;color:#fff;letter-spacing:-0.3px"
            >loading<span style="color:#9b30ff">-games</span></span
          >
        </a>

        <div class="flex items-center gap-7">
          <a href="/games" class="nav-link">Games</a>
          <a href="/configurator" class="nav-link">Configurator</a>
          <a href="/docs" class="nav-link">Docs</a>
          <a
            href="https://github.com/Danishkhan1811/LoadingGame"
            target="_blank"
            rel="noopener"
            class="nav-github"
          >
            <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"
              ><path
                d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"
              ></path></svg
            >
            GitHub
          </a>
        </div>
      </div>
    </nav>

    <main class="flex-1">
      <slot />
    </main>

    <footer class="py-12">
      <div
        class="mx-auto max-w-7xl px-6 flex flex-col sm:flex-row items-center justify-between gap-5"
      >
        <div class="flex items-center gap-2.5">
          <svg
            width="25"
            height="25"
            viewBox="0 0 394 394"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
          >
            <rect x="69" y="150" width="256" height="94" rx="30" fill="#6700D6"></rect>
            <rect
              x="244"
              y="69"
              width="256"
              height="94"
              rx="30"
              transform="rotate(90 244 69)"
              fill="#6700D6"></rect>
            <path d="M176 297.615L217.615 256" stroke="white" stroke-width="4"></path>
            <path d="M217.615 297.615L176 256" stroke="white" stroke-width="4"></path>
            <rect x="94" y="174" width="46" height="46" stroke="white" stroke-width="4"></rect>
            <circle cx="276.5" cy="196.5" r="28.5" stroke="white" stroke-width="4"></circle>
            <path d="M224.713 133H169.287L197 85L224.713 133Z" stroke="white" stroke-width="4"
            ></path>
            <circle
              cx="197"
              cy="197"
              r="189.5"
              stroke="#6700D6"
              stroke-width="15"
              stroke-dasharray="60 20"></circle>
          </svg>

          <span
            style="font-family:'Familjen Grotesk',sans-serif;font-weight:700;font-size:18px;color:#fff"
            >loading<span style="color:#9b30ff">-games</span></span
          >
          <span class="footer-link" style="margin-left:4px">· MIT License</span>
        </div>
        <div class="flex items-center gap-6">
          <a href="https://npmjs.com/package/loading-games" class="footer-link">npm</a>
          <a href="https://github.com/Danishkhan1811/LoadingGame" class="footer-link">GitHub</a>
          <a href="/docs" class="footer-link">Documentation</a>
        </div>
      </div>
    </footer>
  </body>
</html>
