---
import Layout from '../layouts/Layout.astro'
import ThemeConfigurator from '../components/ThemeConfigurator'
---

<Layout title="Configurator — loading-games">
  <div class="mx-auto max-w-6xl px-4 py-12">
    <h1 class="text-3xl font-bold mb-2">Theme Configurator</h1>
    <p class="text-gray-400 mb-10">Pick a game, customize colors, and copy the generated code snippet.</p>
    <ThemeConfigurator client:load />
  </div>
</Layout>
