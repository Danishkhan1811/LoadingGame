---
import Layout from '../layouts/Layout.astro'
import { Code } from 'astro:components'

const reactCode = `import { LoadingGame } from 'loading-games/react'

function MyPage() {
  const [loading, setLoading] = useState(true)

  useEffect(() => {
    fetchData().then(() => setLoading(false))
  }, [])

  return (
    <LoadingGame
      game="snake"
      active={loading}
      onComplete={() => console.log('done!')}
    />
  )
}`

const vueCode = `<script setup>
import { LoadingGame } from 'loading-games/vue'
import { ref } from 'vue'

const loading = ref(true)
fetch('/api/data').then(() => (loading.value = false))
</script>

<template>
  <LoadingGame game="snake" :active="loading" @complete="loading = false" />
</template>`

const vanillaCode = `import 'loading-games'

const el = document.querySelector('loading-game')

// Start
el.setAttribute('active', 'true')

// Set theme
el.theme = { primary: '#6366F1', background: '#0F0F0F' }

// Listen to events
el.addEventListener('lg:score', (e) => console.log(e.detail))

// Stop (triggers exit animation → fires lg:complete)
el.removeAttribute('active')`

const themingCode = `:root {
  --lg-primary:    #6366F1;
  --lg-background: #0F0F0F;
  --lg-surface:    #1A1A2E;
  --lg-text:       #FFFFFF;
  --lg-accent:     #E94560;
}`

const cliCode = `npx loading-games init           # auto-detect & install
npx loading-games init --dry-run  # preview without installing`
---

<Layout title="Docs — loading-games">
  <div class="mx-auto max-w-7xl px-6 py-12">
    <div class="grid lg:grid-cols-[220px_1fr] gap-12">
      <!-- Sidebar -->
      <nav class="hidden lg:block sticky self-start" style="top: 72px">
        <p style="font-family:'JetBrains Mono',monospace;font-size:10px;font-weight:600;text-transform:uppercase;letter-spacing:0.1em;color:#6a6a8a;padding:0 12px;margin-bottom:8px">// Documentation</p>
        <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:2px">
          <li><a href="#installation" class="sidebar-link">Installation</a></li>
          <li><a href="#quick-start" class="sidebar-link">Quick Start</a></li>
          <li><a href="#configuration" class="sidebar-link">Configuration</a></li>
          <li><a href="#theming" class="sidebar-link">Theming</a></li>
          <li><a href="#games" class="sidebar-link">Games</a></li>
          <li><a href="#events" class="sidebar-link">Events</a></li>
          <li><a href="#accessibility" class="sidebar-link">Accessibility</a></li>
          <li><a href="#cli" class="sidebar-link">CLI Tool</a></li>
        </ul>
      </nav>

      <!-- Content -->
      <article style="max-width:none;min-width:0">
        <h1 class="font-display" style="font-size:2.2rem;font-weight:700;color:#fff;margin-bottom:6px;letter-spacing:-0.02em">Documentation</h1>
        <p style="color:#B0B0C8;font-size:15px;margin-bottom:48px">Everything you need to integrate loading-games into your project.</p>

        <!-- ── Installation ── -->
        <section id="installation" style="margin-bottom:48px">
          <h2 class="font-display" style="font-size:1.2rem;font-weight:700;color:#fff;margin-bottom:16px;padding-bottom:8px;border-bottom:1px solid rgba(123,0,255,0.15)">Installation</h2>
          <div class="ide-block" style="margin-bottom:12px">
            <div class="ide-bar">
              <span class="dot" style="background:#ff5f57"></span>
              <span class="dot" style="background:#febc2e"></span>
              <span class="dot" style="background:#28c840"></span>
              <span style="margin-left:8px">terminal</span>
            </div>
            <Code code={`npm install loading-games\n# or\npnpm add loading-games\n# or\nyarn add loading-games`} lang="bash" theme="github-dark" />
          </div>
          <p style="font-size:14px;color:#B0B0C8;margin-bottom:10px">Or scaffold with the CLI (auto-detects your framework):</p>
          <div class="ide-block">
            <div class="ide-bar">
              <span class="dot" style="background:#ff5f57"></span>
              <span class="dot" style="background:#febc2e"></span>
              <span class="dot" style="background:#28c840"></span>
              <span style="margin-left:8px">terminal</span>
            </div>
            <Code code="npx loading-games init" lang="bash" theme="github-dark" />
          </div>
        </section>

        <!-- ── Quick Start ── -->
        <section id="quick-start" style="margin-bottom:48px">
          <h2 class="font-display" style="font-size:1.2rem;font-weight:700;color:#fff;margin-bottom:16px;padding-bottom:8px;border-bottom:1px solid rgba(123,0,255,0.15)">Quick Start</h2>

          <h3 style="font-family:'JetBrains Mono',monospace;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.1em;color:#9b30ff;margin-bottom:10px">React</h3>
          <div class="ide-block" style="margin-bottom:20px">
            <div class="ide-bar">
              <span class="dot" style="background:#ff5f57"></span>
              <span class="dot" style="background:#febc2e"></span>
              <span class="dot" style="background:#28c840"></span>
              <span style="margin-left:8px">MyPage.tsx</span>
            </div>
            <Code code={reactCode} lang="tsx" theme="github-dark" />
          </div>

          <h3 style="font-family:'JetBrains Mono',monospace;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.1em;color:#9b30ff;margin-bottom:10px">Vue 3</h3>
          <div class="ide-block" style="margin-bottom:20px">
            <div class="ide-bar">
              <span class="dot" style="background:#ff5f57"></span>
              <span class="dot" style="background:#febc2e"></span>
              <span class="dot" style="background:#28c840"></span>
              <span style="margin-left:8px">MyPage.vue</span>
            </div>
            <Code code={vueCode} lang="vue" theme="github-dark" />
          </div>

          <h3 style="font-family:'JetBrains Mono',monospace;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.1em;color:#9b30ff;margin-bottom:10px">Vanilla JS / Web Component</h3>
          <div class="ide-block">
            <div class="ide-bar">
              <span class="dot" style="background:#ff5f57"></span>
              <span class="dot" style="background:#febc2e"></span>
              <span class="dot" style="background:#28c840"></span>
              <span style="margin-left:8px">main.js</span>
            </div>
            <Code code={vanillaCode} lang="js" theme="github-dark" />
          </div>
        </section>

        <!-- ── Configuration ── -->
        <section id="configuration" style="margin-bottom:48px">
          <h2 class="font-display" style="font-size:1.2rem;font-weight:700;color:#fff;margin-bottom:16px;padding-bottom:8px;border-bottom:1px solid rgba(123,0,255,0.15)">Configuration</h2>
          <div style="overflow-x:auto">
            <table style="width:100%;font-size:13px;border-collapse:collapse">
              <thead>
                <tr style="border-bottom:1px solid rgba(123,0,255,0.15)">
                  <th style="text-align:left;padding:10px 16px 10px 0;color:#6a6a8a;font-weight:600;font-size:11px;text-transform:uppercase;letter-spacing:0.07em;font-family:'JetBrains Mono',monospace">Prop</th>
                  <th style="text-align:left;padding:10px 16px 10px 0;color:#6a6a8a;font-weight:600;font-size:11px;text-transform:uppercase;letter-spacing:0.07em;font-family:'JetBrains Mono',monospace">Type</th>
                  <th style="text-align:left;padding:10px 16px 10px 0;color:#6a6a8a;font-weight:600;font-size:11px;text-transform:uppercase;letter-spacing:0.07em;font-family:'JetBrains Mono',monospace">Default</th>
                  <th style="text-align:left;padding:10px 0;color:#6a6a8a;font-weight:600;font-size:11px;text-transform:uppercase;letter-spacing:0.07em;font-family:'JetBrains Mono',monospace">Description</th>
                </tr>
              </thead>
              <tbody style="color:#B0B0C8">
                {[
                  ['game',          "GameName | 'random'",      "'random'",   'Which game to render'],
                  ['active',        'boolean',                  'false',      'Starts/stops the game'],
                  ['theme',         'ThemeObject',              'auto',       'Colors: primary, background, surface, text, accent'],
                  ['size',          "'sm'|'md'|'lg'|'full'",    "'md'",       'Preset canvas size'],
                  ['delay',         'number (ms)',              '800',        'Wait before showing game'],
                  ['minDisplay',    'number (ms)',              '0',          'Min display time once shown'],
                  ['exitAnimation', "'fade'|'slide'|'none'",    "'fade'",     'How the game disappears'],
                  ['saveScores',    'boolean',                  'true',       'Persist personal bests in localStorage'],
                  ['namespace',     'string',                   'undefined',  'Scope score storage per instance'],
                ].map(([prop, type, def, desc]) => (
                  <tr style="border-bottom:1px solid rgba(123,0,255,0.08)">
                    <td style="padding:9px 16px 9px 0"><code style="font-family:'JetBrains Mono',monospace;font-size:12px;color:#c060ff">{prop}</code></td>
                    <td style="padding:9px 16px 9px 0"><code style="font-family:'JetBrains Mono',monospace;font-size:12px;color:#e8b4ff">{type}</code></td>
                    <td style="padding:9px 16px 9px 0"><code style="font-family:'JetBrains Mono',monospace;font-size:12px;color:#9b30ff">{def}</code></td>
                    <td style="padding:9px 0;color:#B0B0C8">{desc}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </section>

        <!-- ── Theming ── -->
        <section id="theming" style="margin-bottom:48px">
          <h2 class="font-display" style="font-size:1.2rem;font-weight:700;color:#fff;margin-bottom:16px;padding-bottom:8px;border-bottom:1px solid rgba(123,0,255,0.15)">Theming</h2>
          <p style="font-size:14px;color:#B0B0C8;margin-bottom:12px">Theme resolution priority (highest first):</p>
          <ol style="font-size:14px;color:#B0B0C8;padding-left:20px;margin-bottom:16px;display:flex;flex-direction:column;gap:6px">
            <li>Explicit <code style="font-family:'JetBrains Mono',monospace;font-size:12px;color:#c060ff">theme</code> prop / attribute</li>
            <li>CSS variables: <code style="font-family:'JetBrains Mono',monospace;font-size:12px;color:#c060ff">--lg-primary</code>, <code style="font-family:'JetBrains Mono',monospace;font-size:12px;color:#c060ff">--lg-background</code>, …</li>
            <li>System <code style="font-family:'JetBrains Mono',monospace;font-size:12px;color:#c060ff">prefers-color-scheme</code> detection</li>
          </ol>
          <div class="ide-block">
            <div class="ide-bar">
              <span class="dot" style="background:#ff5f57"></span>
              <span class="dot" style="background:#febc2e"></span>
              <span class="dot" style="background:#28c840"></span>
              <span style="margin-left:8px">styles.css</span>
            </div>
            <Code code={themingCode} lang="css" theme="github-dark" />
          </div>
        </section>

        <!-- ── Games ── -->
        <section id="games" style="margin-bottom:48px">
          <h2 class="font-display" style="font-size:1.2rem;font-weight:700;color:#fff;margin-bottom:16px;padding-bottom:8px;border-bottom:1px solid rgba(123,0,255,0.15)">Available Games</h2>
          <p style="font-size:14px;color:#B0B0C8;margin-bottom:16px">All games are lazy-loaded. Use <code style="font-family:'JetBrains Mono',monospace;font-size:12px;color:#c060ff">game="random"</code> to pick one at random.</p>
          <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:10px">
            {[
              { name: 'snake',        size: '2.8 kB', controls: 'Arrow keys / swipe',    ready: true  },
              { name: 'flappy',       size: '1.9 kB', controls: 'Spacebar / tap',         ready: true  },
              { name: 'memory-cards', size: '2.4 kB', controls: 'Click / tap / keyboard', ready: true  },
              { name: 'whack-a-mole', size: '2.4 kB', controls: 'Click / tap / 1–9',      ready: true  },
              { name: 'brick-breaker',size: '~1 kB',  controls: 'Mouse / touch',          ready: false },
              { name: '2048',         size: '~1 kB',  controls: 'Arrow keys / swipe',     ready: false },
              { name: 'wordle-lite',  size: '~1 kB',  controls: 'Keyboard',               ready: false },
              { name: 'asteroids',    size: '~1 kB',  controls: 'Arrow keys + space',     ready: false },
            ].map((g) => (
              <div style={`background:rgba(15,15,26,0.7);border:1px solid ${g.ready ? 'rgba(123,0,255,0.2)' : 'rgba(123,0,255,0.08)'};border-radius:10px;padding:12px 14px;opacity:${g.ready ? 1 : 0.55};backdrop-filter:blur(8px)`}>
                <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:4px">
                  <code style="font-family:'JetBrains Mono',monospace;font-size:12px;color:#c060ff">{g.name}</code>
                  <span style={`font-family:'JetBrains Mono',monospace;font-size:10px;padding:2px 8px;border-radius:20px;font-weight:600;letter-spacing:0.05em;${g.ready ? 'color:#39d353;background:rgba(57,211,83,0.1);border:1px solid rgba(57,211,83,0.25)' : 'color:#6a6a8a;background:rgba(106,106,138,0.1);border:1px solid rgba(106,106,138,0.2)'}`}>
                    {g.ready ? 'LIVE' : 'v2.1'}
                  </span>
                </div>
                <div style="display:flex;align-items:center;justify-content:space-between">
                  <span style="font-size:11px;color:#B0B0C8">{g.controls}</span>
                  <span style="font-size:11px;color:#9b30ff;font-family:'JetBrains Mono',monospace">{g.size}</span>
                </div>
              </div>
            ))}
          </div>
        </section>

        <!-- ── Events ── -->
        <section id="events" style="margin-bottom:48px">
          <h2 class="font-display" style="font-size:1.2rem;font-weight:700;color:#fff;margin-bottom:16px;padding-bottom:8px;border-bottom:1px solid rgba(123,0,255,0.15)">Events</h2>
          <div style="overflow-x:auto">
            <table style="width:100%;font-size:13px;border-collapse:collapse">
              <thead>
                <tr style="border-bottom:1px solid rgba(123,0,255,0.15)">
                  <th style="text-align:left;padding:10px 16px 10px 0;color:#6a6a8a;font-weight:600;font-size:11px;text-transform:uppercase;letter-spacing:0.07em;font-family:'JetBrains Mono',monospace">Event</th>
                  <th style="text-align:left;padding:10px 16px 10px 0;color:#6a6a8a;font-weight:600;font-size:11px;text-transform:uppercase;letter-spacing:0.07em;font-family:'JetBrains Mono',monospace">Detail Type</th>
                  <th style="text-align:left;padding:10px 0;color:#6a6a8a;font-weight:600;font-size:11px;text-transform:uppercase;letter-spacing:0.07em;font-family:'JetBrains Mono',monospace">Description</th>
                </tr>
              </thead>
              <tbody>
                {[
                  ['lg:score',    'Score',      'Fires on every score change'],
                  ['lg:gameover', 'GameResult', 'Fires when a game round ends'],
                  ['lg:complete', '—',          'Exit animation finished — game fully removed'],
                  ['lg:error',    'Error',      'Fires on loading or runtime error'],
                ].map(([evt, detail, desc]) => (
                  <tr style="border-bottom:1px solid rgba(123,0,255,0.08)">
                    <td style="padding:9px 16px 9px 0"><code style="font-family:'JetBrains Mono',monospace;font-size:12px;color:#ff9580">{evt}</code></td>
                    <td style="padding:9px 16px 9px 0"><code style="font-family:'JetBrains Mono',monospace;font-size:12px;color:#e8b4ff">{detail}</code></td>
                    <td style="padding:9px 0;color:#B0B0C8;font-size:13px">{desc}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </section>

        <!-- ── Accessibility ── -->
        <section id="accessibility" style="margin-bottom:48px">
          <h2 class="font-display" style="font-size:1.2rem;font-weight:700;color:#fff;margin-bottom:16px;padding-bottom:8px;border-bottom:1px solid rgba(123,0,255,0.15)">Accessibility</h2>
          <ul style="font-size:14px;color:#B0B0C8;padding-left:20px;display:flex;flex-direction:column;gap:8px">
            <li><code style="font-family:'JetBrains Mono',monospace;font-size:12px;color:#c060ff">role="application"</code> + game-specific <code style="font-family:'JetBrains Mono',monospace;font-size:12px;color:#c060ff">aria-label</code> on every canvas</li>
            <li>Skip link "Skip game, wait for loading" — always first tab stop</li>
            <li><code style="font-family:'JetBrains Mono',monospace;font-size:12px;color:#c060ff">prefers-reduced-motion</code>: static fallback, no gameplay</li>
            <li>Auto-pause on tab hidden (<code style="font-family:'JetBrains Mono',monospace;font-size:12px;color:#c060ff">visibilitychange</code>)</li>
            <li>Virtual D-pad on touch for keyboard-dependent games</li>
            <li>Min 44×44px tap targets (WCAG 2.5.5 AAA)</li>
          </ul>
        </section>

        <!-- ── CLI ── -->
        <section id="cli" style="margin-bottom:48px">
          <h2 class="font-display" style="font-size:1.2rem;font-weight:700;color:#fff;margin-bottom:16px;padding-bottom:8px;border-bottom:1px solid rgba(123,0,255,0.15)">CLI Tool</h2>
          <div class="ide-block" style="margin-bottom:14px">
            <div class="ide-bar">
              <span class="dot" style="background:#ff5f57"></span>
              <span class="dot" style="background:#febc2e"></span>
              <span class="dot" style="background:#28c840"></span>
              <span style="margin-left:8px">terminal</span>
            </div>
            <Code code={cliCode} lang="bash" theme="github-dark" />
          </div>
          <p style="font-size:14px;color:#B0B0C8">
            The CLI detects your framework from <code style="font-family:'JetBrains Mono',monospace;font-size:12px;color:#c060ff">package.json</code> dependencies and config files
            (<code style="font-family:'JetBrains Mono',monospace;font-size:12px;color:#c060ff">next.config.*</code>,
            <code style="font-family:'JetBrains Mono',monospace;font-size:12px;color:#c060ff">nuxt.config.*</code>,
            <code style="font-family:'JetBrains Mono',monospace;font-size:12px;color:#c060ff">svelte.config.*</code>),
            then prints a ready-to-paste framework-specific snippet.
          </p>
        </section>
      </article>
    </div>
  </div>
</Layout>
