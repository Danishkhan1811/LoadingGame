---
import Layout from '../layouts/Layout.astro'
import GamesGrid from '../components/GamesGrid'
---

<Layout title="Games — loading-games">
  <div class="mx-auto max-w-5xl px-6 py-14">

    <!-- Page Header -->
    <div class="mb-10">
      <div class="flex items-center gap-2 mb-3" style="font-size:13px;color:#8b949e">
        <a href="/" style="color:#8b949e;text-decoration:none;hover:color:#e6edf3">Home</a>
        <span>/</span>
        <span style="color:#e6edf3">Games</span>
      </div>
      <h1 class="text-4xl font-bold mb-2" style="color:#e6edf3">
        Playable Games
      </h1>
      <p style="font-size:16px;color:#8b949e;max-width:540px">
        Click any game to open it in a popup. Each game is a separate lazy-loaded chunk — only fetched when first played.
      </p>
      <div class="flex items-center gap-4 mt-4" style="font-size:13px">
        <span style="color:#39d353;display:flex;align-items:center;gap:6px">
          <span style="width:8px;height:8px;border-radius:50%;background:#39d353;display:inline-block"></span>
          4 games live
        </span>
        <span style="color:#8b949e">·</span>
        <span style="color:#8b949e">4 more in v1.1</span>
      </div>
    </div>

    <!-- Interactive Game Cards (React island with modal) -->
    <GamesGrid client:load />

    <!-- Coming Soon -->
    <div class="mt-10 card" style="padding:28px;text-align:center">
      <p style="font-size:13px;color:#8b949e;margin-bottom:14px;font-weight:600;text-transform:uppercase;letter-spacing:0.08em">Coming in v1.1</p>
      <div style="display:flex;justify-content:center;gap:28px;font-size:40px;opacity:0.4;margin-bottom:12px">
        <span title="Brick Breaker">🧱</span>
        <span title="2048">🔢</span>
        <span title="Wordle Lite">📝</span>
        <span title="Asteroids">🚀</span>
      </div>
      <p style="font-size:14px;color:#8b949e">Brick Breaker · 2048 · Wordle Lite · Asteroids</p>
    </div>
  </div>
</Layout>
