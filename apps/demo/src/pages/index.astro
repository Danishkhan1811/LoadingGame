---
import Layout from '../layouts/Layout.astro'
import CodeTabs from '../components/CodeTabs'
import GamePreview from '../components/GamePreview'
---

<Layout title="loading-games — Playable mini-games for loading states">

  <!-- ── Hero ── -->
  <section id="hero" style="position:relative;overflow:hidden;padding:100px 0 88px;min-height:calc(100vh - 56px);display:flex;align-items:center">

    <!-- Animated dot-grid background -->
    <div id="hero-grid" style="position:absolute;inset:0;pointer-events:none;overflow:hidden;z-index:0">
      <svg id="grid-svg" width="100%" height="100%" xmlns="http://www.w3.org/2000/svg" style="position:absolute;inset:0;opacity:1">
        <defs>
          <pattern id="dot-pattern" x="0" y="0" width="40" height="40" patternUnits="userSpaceOnUse">
            <circle cx="1" cy="1" r="1" fill="rgba(123,0,255,0.25)"/>
          </pattern>
        </defs>
        <rect id="grid-rect" width="140%" height="140%" x="-20%" y="-20%" fill="url(#dot-pattern)"/>
      </svg>
    </div>

    <!-- Glow blobs -->
    <div class="glow-blob" style="width:700px;height:700px;background:#7b00ff;top:-250px;left:-200px;animation-delay:0s"></div>
    <div class="glow-blob" style="width:500px;height:500px;background:#6200ea;bottom:-180px;right:-100px;animation-delay:2.5s"></div>

    <div class="mx-auto max-w-7xl px-6 w-full" style="position:relative;z-index:1">
      <div class="grid lg:grid-cols-2 gap-16 items-center">

        <!-- Left: Copy -->
        <div style="display:flex;flex-direction:column;gap:28px">

          <!-- Version badge -->
          <div style="display:inline-flex;align-items:center;gap:8px;background:rgba(123,0,255,0.1);border:1px solid rgba(123,0,255,0.28);border-radius:100px;padding:5px 14px;width:fit-content">
            <span class="led led-blink" style="background:#9b30ff;color:#9b30ff"></span>
            <span style="font-family:'JetBrains Mono',monospace;font-size:12px;font-weight:500;color:#B0B0C8">v2.0.1 — Open Source &amp; Production Ready</span>
          </div>

          <!-- Headline -->
          <h1 class="font-display" style="font-size:clamp(4.6rem,4vw,2.8rem);font-weight:700;line-height:1.02;letter-spacing:-0.03em;color:#fff;margin:0">
            Turn boring<br/>
            <span class="purple-glow-text">loading screens</span><br/>
            into playable games
          </h1>

          <!-- Subtext -->
          <p style="font-size:17px;color:#B0B0C8;line-height:1.72;max-width:460px;margin:0">
            Zero-dependency library that replaces loading spinners with <span style="color:#fff;font-weight:600">engaging mini-games</span>. Users play while they wait — retention guaranteed.
          </p>

          <!-- CTAs -->
          <div style="display:flex;flex-wrap:wrap;gap:12px;align-items:center">
            <a href="/games" class="btn-primary" style="text-decoration:none">Play games →</a>
            <a href="/docs"  class="btn-ghost"   style="text-decoration:none">View docs</a>
            <!-- npm pill -->
            <div style="display:inline-flex;align-items:center;gap:10px;background:rgba(13,13,31,0.85);border:1px solid rgba(123,0,255,0.22);border-radius:10px;padding:9px 14px">
              <code style="font-family:'JetBrains Mono',monospace;font-size:12.5px;color:#c060ff;letter-spacing:0.02em">npm i loading-games</code>
              <button
                id="copy-btn"
                onclick="navigator.clipboard.writeText('npm install loading-games');const i=this.querySelector('svg');i.style.opacity='0';setTimeout(()=>{i.style.opacity='1'},1400)"
                style="background:none;border:none;cursor:pointer;color:#6a6a8a;padding:0;line-height:1;display:flex;align-items:center;transition:color 0.15s"
                onmouseover="this.style.color='#9b30ff'"
                onmouseout="this.style.color='#6a6a8a'"
                title="Copy"
              >
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
                </svg>
              </button>
            </div>
          </div>

          <!-- Stats HUD -->
          <div style="display:flex;align-items:center;gap:20px;padding-top:8px;padding-left:2px">
            <div class="hud-stat">
              <span class="hud-val" id="stat-kb">10 kB</span>
              <span class="hud-label">Core bundle</span>
            </div>
            <div class="hud-divider"></div>
            <div class="hud-stat">
              <span class="hud-val" id="stat-games">4</span>
              <span class="hud-label">Games live</span>
            </div>
            <div class="hud-divider"></div>
            <div class="hud-stat">
              <span class="hud-val" id="stat-deps">0</span>
              <span class="hud-label">Dependencies</span>
            </div>
          </div>
        </div>

        <!-- Right: CRT game preview -->
        <div style="position:relative;display:flex;justify-content:center">
          <!-- Outer glow -->
          <div style="position:absolute;inset:-20px;background:radial-gradient(ellipse at center,rgba(123,0,255,0.2) 0%,transparent 70%);pointer-events:none;border-radius:32px"></div>

          <div class="crt-bezel" style="width:100%;max-width:480px">
            <!-- Bezel top bar -->
            <div style="display:flex;align-items:center;gap:7px;padding:10px 14px 8px;background:rgba(15,15,26,0.9)">
              <span style="width:10px;height:10px;border-radius:50%;background:#ff5f57;display:block;flex-shrink:0"></span>
              <span style="width:10px;height:10px;border-radius:50%;background:#febc2e;display:block;flex-shrink:0"></span>
              <span style="width:10px;height:10px;border-radius:50%;background:#28c840;display:block;flex-shrink:0"></span>
              <span style="font-family:'JetBrains Mono',monospace;font-size:11px;color:#6a6a8a;margin-left:8px;flex:1;text-align:center;letter-spacing:0.05em">LOADING-GAMES // LIVE PREVIEW</span>
            </div>
            <!-- CRT Screen -->
            <div class="crt-screen" style="height:380px">
              <div class="crt-vignette"></div>
              <GamePreview client:load game="snake" active={true} />
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ── Features ── -->
  <section style="border-top:1px solid rgba(123,0,255,0.1);padding:96px 0;position:relative;overflow:hidden">
    <div class="glow-blob" style="width:500px;height:500px;background:#4d00c4;top:-100px;right:-100px;animation-delay:1s"></div>
    <div class="mx-auto max-w-7xl px-6" style="position:relative">
      <div style="text-align:center;margin-bottom:60px" class="reveal">
        <h2 class="font-display" style="font-size:clamp(1.75rem,3vw,2.5rem);font-weight:700;color:#fff;margin-bottom:10px;letter-spacing:-0.02em">Why developers love it</h2>
        <p style="color:#B0B0C8;font-size:16px">Built for performance, designed for simplicity</p>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
        {[
          { icon:'◈', title:'Zero Dependencies',   body:'Pure Web Component. No runtime deps. Works everywhere, forever.', delay:'0ms' },
          { icon:'⬡', title:'<3 kB per Game',      body:'Lazy-loaded chunks. Core is 10 kB. Each game ~2 kB gzipped.', delay:'80ms', featured: true },
          { icon:'◉', title:'4 Games Live',         body:'Snake, Flappy, Memory Cards, Whack-a-Mole. 4 more in v2.1.', delay:'160ms' },
          { icon:'⬢', title:'Any Framework',        body:'First-class React, Vue 3, Svelte wrappers + TypeScript.', delay:'240ms' },
        ].map((f) => (
          <div class={`glass-card reveal ${f.featured ? 'feature-featured' : ''}`} style={`padding:28px 24px;transition-delay:${f.delay}`}>
            <div style="font-size:26px;color:#9b30ff;margin-bottom:16px;font-family:'JetBrains Mono',monospace;line-height:1">{f.icon}</div>
            <h3 class="font-display" style="font-weight:700;font-size:15px;color:#fff;margin-bottom:8px" set:html={f.title}></h3>
            <p style="font-size:13px;color:#B0B0C8;line-height:1.65">{f.body}</p>
            {f.featured && (
              <div style="margin-top:14px;display:inline-block;background:rgba(123,0,255,0.15);border:1px solid rgba(123,0,255,0.3);border-radius:100px;padding:3px 10px;font-size:10px;font-family:'JetBrains Mono',monospace;color:#9b30ff;letter-spacing:0.06em">FEATURED</div>
            )}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── Code Tabs ── -->
  <section style="border-top:1px solid rgba(123,0,255,0.1);padding:96px 0;position:relative;overflow:hidden">
    <div class="glow-blob" style="width:500px;height:500px;background:#6200ea;top:50%;left:-150px;transform:translateY(-50%);animation-delay:0.5s"></div>
    <div class="glow-blob" style="width:400px;height:400px;background:#3d0099;top:50%;right:-100px;transform:translateY(-50%);animation-delay:2s"></div>
    <div class="mx-auto max-w-7xl px-6" style="position:relative">
      <div style="text-align:center;margin-bottom:52px" class="reveal">
        <h2 class="font-display" style="font-size:clamp(1.75rem,3vw,2.5rem);font-weight:700;color:#fff;margin-bottom:10px;letter-spacing:-0.02em">Get started in seconds</h2>
        <p style="color:#B0B0C8;font-size:16px">One component. Any framework. Full TypeScript support.</p>
      </div>
      <div class="reveal">
        <CodeTabs client:load />
      </div>
    </div>
  </section>

  <!-- ── Games showcase ── -->
  <section style="border-top:1px solid rgba(123,0,255,0.1);padding:96px 0;position:relative;overflow:hidden">
    <div class="glow-blob" style="width:600px;height:600px;background:#4d00c4;bottom:-200px;left:50%;transform:translateX(-50%);animation-delay:1.5s"></div>
    <div class="mx-auto max-w-7xl px-6" style="position:relative">
      <div style="text-align:center;margin-bottom:52px" class="reveal">
        <h2 class="font-display" style="font-size:clamp(1.75rem,3vw,2.5rem);font-weight:700;color:#fff;margin-bottom:10px;letter-spacing:-0.02em">4 Games Live Now</h2>
        <p style="color:#B0B0C8;font-size:16px">Each game is a lazy-loaded chunk — only fetched when first activated</p>
      </div>

      <div class="grid grid-cols-2 lg:grid-cols-4 gap-5">
        {[
          { name:'Snake',        slug:'snake',        emoji:'🐍', color:'#39d353', blink:true  },
          { name:'Flappy Bird',  slug:'flappy',       emoji:'🐦', color:'#a855f7', blink:false },
          { name:'Memory Cards', slug:'memory-cards', emoji:'🃏', color:'#c060ff', blink:false },
          { name:'Whack-a-Mole', slug:'whack-a-mole', emoji:'🔨', color:'#f97316', blink:false },
        ].map((g, i) => (
          <a
            href="/games"
            class="cart-card reveal"
            style={`padding:28px 20px;text-align:center;text-decoration:none;display:block;transition-delay:${i * 80}ms`}
          >
            <span class="cart-icon">{g.emoji}</span>
            <div class="font-display" style="font-weight:700;font-size:14px;color:#fff;margin:12px 0 10px;letter-spacing:-0.01em">{g.name}</div>
            <div style="display:inline-flex;align-items:center;gap:6px;background:rgba(15,15,26,0.8);border:1px solid rgba(255,255,255,0.06);border-radius:100px;padding:4px 10px">
              <span class={`led ${g.blink ? 'led-blink' : ''}`} style={`background:${g.color};color:${g.color};box-shadow:0 0 6px ${g.color}`}></span>
              <span style={`font-family:'JetBrains Mono',monospace;font-size:10px;font-weight:600;color:${g.color};letter-spacing:0.05em`}>LIVE</span>
            </div>
          </a>
        ))}
      </div>

      <div style="text-align:center;margin-top:40px" class="reveal">
        <a href="/games" class="btn-primary" style="text-decoration:none">Play All Games →</a>
      </div>

      <!-- Coming soon — locked inventory row -->
      <div class="reveal" style="margin-top:44px;border:1px dashed rgba(123,0,255,0.2);border-radius:16px;padding:28px;background:rgba(10,10,15,0.6);backdrop-filter:blur(8px)">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:20px">
          <p style="font-family:'JetBrains Mono',monospace;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.1em;color:#6a6a8a;margin:0">
            // Locked — Coming in v2.1
          </p>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="rgba(123,0,255,0.4)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>
          </svg>
        </div>
        <div style="display:flex;justify-content:center;gap:32px">
          {['🧱','🔢','📝','🚀'].map((e) => (
            <div style="position:relative;text-align:center">
              <div style="font-size:36px;filter:grayscale(1) brightness(0.35)">{e}</div>
              <div style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="rgba(123,0,255,0.5)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                </svg>
              </div>
            </div>
          ))}
        </div>
      </div>

    </div>
  </section>

</Layout>

<style>
  .feature-featured {
    border-color: rgba(123,0,255,0.35) !important;
    background: rgba(15,15,26,0.9) !important;
  }
</style>

<script>
  /* Scroll reveal */
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((e, i) => {
        if (e.isIntersecting) {
          const el = e.target as HTMLElement
          const delay = el.style.transitionDelay || '0ms'
          setTimeout(() => el.classList.add('visible'), parseInt(delay))
          observer.unobserve(e.target)
        }
      })
    },
    { threshold: 0.08 }
  )
  document.querySelectorAll('.reveal').forEach((el) => observer.observe(el))

  /* Animated hero grid drift */
  const rect = document.getElementById('grid-rect')
  if (rect) {
    let x = 0, y = 0
    const drift = () => {
      x = (x + 0.012) % 40
      y = (y + 0.012) % 40
      rect.setAttribute('x', `${-20 + x / 40 * 2}%`)
      rect.setAttribute('y', `${-20 + y / 40 * 2}%`)
      requestAnimationFrame(drift)
    }
    drift()
  }

  /* Count-up on scroll into view */
  const statsObserver = new IntersectionObserver(
    (entries) => {
      if (entries[0]?.isIntersecting) {
        const statGames = document.getElementById('stat-games')
        if (statGames) {
          let n = 0
          const t = setInterval(() => {
            statGames.textContent = String(Math.min(++n, 4))
            if (n >= 4) clearInterval(t)
          }, 120)
        }
        statsObserver.disconnect()
      }
    },
    { threshold: 0.5 }
  )
  const kbEl = document.getElementById('stat-kb')
  if (kbEl) statsObserver.observe(kbEl)
</script>